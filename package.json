{
  "name": "tidal-ties",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Tidal Ties - a social fishing game (low-poly 3D, mobile via Capacitor)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "sim": "node scripts/sim.ts",
    "sim:wait": "node scripts/waitsim.ts",
    "sim:regions": "node scripts/regionsim.ts",
    "sim:gear": "node scripts/gearsim.ts",
    "sim:boat": "node scripts/boatsim.ts",
    "sim:bait": "node scripts/baitsim.ts",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync android && cap open android",
    "cap:ios": "npm run build && cap sync ios && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  }
}
